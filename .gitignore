# Godot 4+ specific ignores
.godot/
/android/

# All node_modules everywhere
node_modules/

# Server
server/*.db
server/*.db-wal
server/*.db-shm

# Futures Server
server-futures/*.db
server-futures/*.db-wal
server-futures/*.db-shm
server-futures/server.log

# Local runtime logs
*.log

# Environment
.env
*.orig
.asset-backups/

# Godot imports generated for web-only share images
web/public/win.jpg.import
web/public/lose.jpg.import

# MCP
.mcp.json
addons/godot_mcp/

# Godot Web Export
web/public/godot/

# Decibel test wallet - contains private key, never commit
aptos-test-wallet.txt
backups/

# Android signing keystore + the password file living next to it.
# CRITICAL: leaking either == anyone can sign updates impersonating us
# on the Solana dApp Store. Both must live ONLY in our password
# manager + offline backup, NEVER in version control.
android-keystore/
twa/

# One-shot dev scripts (SSH probes, bubblewrap drivers). They contain
# hard-coded paths to local sensitive files (keystore path, prod SSH
# creds piped via env) — keep them out of the repo to make leaks
# harder when someone diffs commits.
.tmp-*
